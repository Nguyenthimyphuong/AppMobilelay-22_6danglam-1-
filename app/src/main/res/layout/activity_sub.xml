<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.SubActivity"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#FFF7FB">

    <!-- Thanh tiêu đề -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="#A9F1A8">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/left" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="CHI TIẾT SẢN PHẨM"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <Space
            android:layout_width="50dp"
            android:layout_height="50dp" />

    </LinearLayout>

    <!-- Nội dung chi tiết -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Ảnh sản phẩm -->
            <ImageView
                android:id="@+id/img_sub_Product"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:src="@drawable/itemuser1"
                android:scaleType="fitCenter"
                android:background="#FFFFFF" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- Tên sản phẩm -->
            <TextView
                android:id="@+id/txt_nameProduct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nước giặt xả Dr.Spock Organics 2L"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="8dp" />

            <!-- Giá sản phẩm -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giá: "
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <TextView
                    android:id="@+id/txt_priceProduct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="120.000 VND"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#FF6F61" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="15dp" />

            <!-- Mô tả sản phẩm -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mô tả sản phẩm"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sản phẩm dành cho mẹ và bé, đảm bảo chất lượng, an toàn khi sử dụng. Phù hợp cho nhu cầu chăm sóc bé hằng ngày."
                android:textSize="15sp"
                android:textColor="#555555"
                android:lineSpacingExtra="4dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="18dp" />

            <!-- Chọn số lượng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Số lượng"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <TextView
                    android:id="@+id/btn_tru_chitiet"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="-"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/custom_button_admin_page" />

                <TextView
                    android:id="@+id/txt_so_luong_chitiet"
                    android:layout_width="50dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <TextView
                    android:id="@+id/btn_cong_chitiet"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="+"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/custom_button_admin_page" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp" />

            <!-- Nút thêm vào giỏ -->
            <Button
                android:id="@+id/btn_giohang"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/custom_button_admin_page"
                android:text="THÊM VÀO GIỎ HÀNG"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>