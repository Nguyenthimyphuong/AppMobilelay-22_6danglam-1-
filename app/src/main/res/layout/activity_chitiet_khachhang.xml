<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7EEF5"
    android:fitsSystemWindows="true">

    <!-- Thanh tiêu đề -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="#E91E63"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="8dp"
            android:src="@drawable/left" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="CHI TIẾT KHÁCH HÀNG"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="50dp"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Thông tin khách hàng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_myplaces" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="15dp">

            <TextView
                android:id="@+id/txt_maKH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KH01"
                android:textStyle="bold"
                android:textColor="#E91E63"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/txt_tenKH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên khách hàng"
                android:textStyle="bold"
                android:textSize="19sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/txt_sdt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số điện thoại"
                android:textSize="15sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/txt_diachi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Địa chỉ"
                android:textSize="15sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/txt_ngayDK"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày đăng ký"
                android:textSize="15sp"
                android:textColor="#333333" />

        </LinearLayout>
    </LinearLayout>

    <!-- Tiêu đề lịch sử mua hàng -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LỊCH SỬ MUA HÀNG"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#E91E63"
        android:gravity="center"
        android:padding="10dp" />

    <!-- Danh sách hóa đơn -->
    <ListView
        android:id="@+id/lv_hoaDon"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:background="#FFFFFF"
        android:dividerHeight="8dp"
        android:padding="8dp" />

    <!-- Nút xóa khách hàng -->
    <Button
        android:id="@+id/btn_xoaKH"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_margin="10dp"
        android:text="Xóa khách hàng"
        android:textStyle="bold" />

</LinearLayout>