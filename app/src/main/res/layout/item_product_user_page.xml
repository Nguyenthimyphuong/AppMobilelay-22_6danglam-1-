<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/custom_image"
    android:padding="8dp"
    android:descendantFocusability="blocksDescendants">

    <ImageView
        android:id="@+id/image_Product"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:src="@drawable/itemuser1"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/txt_tenSP"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Nước giặt xả Dr.Spock Organics 2L"
        android:textSize="15sp"
        android:textColor="#333333"
        android:gravity="center"
        android:maxLines="2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:descendantFocusability="blocksDescendants">

        <TextView
            android:id="@+id/txt_giaSP"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Giá: 190000"
            android:textSize="14sp"
            android:textColor="#333333"
            android:gravity="start" />

        <Button
            android:id="@+id/btn_cart_product"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/cart"
            android:focusable="false"
            android:clickable="true" />

    </LinearLayout>

</LinearLayout>