<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Ảnh NCC -->
        <ImageView
            android:id="@+id/imgNCC"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/client"
            android:scaleType="centerCrop" />

        <!-- Thông tin NCC -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp">

            <!-- Mã NCC -->
            <TextView
                android:id="@+id/txtMaNCC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NCC001"
                android:textStyle="bold"
                android:textColor="#FF6B81"
                android:textSize="18sp" />

            <!-- Tên NCC -->
            <TextView
                android:id="@+id/txtTenNCC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pigeon Việt Nam"
                android:textStyle="bold"
                android:textSize="16sp" />

            <!-- Địa chỉ -->
            <TextView
                android:id="@+id/txtDiaChi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hà Nội" />

            <!-- Số điện thoại -->
            <TextView
                android:id="@+id/txtSDT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0901234567" />

        </LinearLayout>

        <!-- Nút chi tiết trong từng ô NCC -->
        <Button
            android:id="@+id/btnChiTietNCC"
            android:layout_width="82dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="Chi tiết"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#7E57C2"
            android:focusable="false"
            android:focusableInTouchMode="false" />

    </LinearLayout>

</androidx.cardview.widget.CardView>