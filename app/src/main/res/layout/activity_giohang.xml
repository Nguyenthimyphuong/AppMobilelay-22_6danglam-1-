<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.giohang"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#FFF7FB">

    <!-- Thanh tiêu đề -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="#A9F1A8">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/left" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="GIỎ HÀNG"
            android:textSize="21sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <Space
            android:layout_width="50dp"
            android:layout_height="50dp" />

    </LinearLayout>

    <!-- Tiêu đề danh sách -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="DANH SÁCH SẢN PHẨM"
        android:gravity="center"
        android:textStyle="italic"
        android:textSize="19sp"
        android:textColor="#FF9182" />

    <!-- Danh sách giỏ hàng -->
    <ListView
        android:id="@+id/lv_giohang"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="6dp"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:paddingBottom="6dp"
        android:clipToPadding="false" />

    <!-- Tổng tiền và thanh toán -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="95dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp">

        <TextView
            android:id="@+id/txt_tong_tien"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tổng tiền: 0 VND"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#333333" />

        <Button
            android:id="@+id/btn_thanhtoan"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="THANH TOÁN"
            android:textColor="#FFFFFF"
            android:background="@drawable/custom_button_admin_page" />

    </LinearLayout>

</LinearLayout>