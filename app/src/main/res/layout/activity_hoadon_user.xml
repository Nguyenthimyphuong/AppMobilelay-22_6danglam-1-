<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_hoadon_user"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF7FB"
    android:fitsSystemWindows="true">

    <!-- Thanh tiêu đề -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="#A9F1A8">

        <!-- Nút quay về trang chủ -->
        <ImageView
            android:id="@+id/btn_back_hoadon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/left" />

        <!-- Tiêu đề trang hóa đơn -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="HÓA ĐƠN"
            android:textColor="#FFFFFF"
            android:textSize="21sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="50dp"
            android:layout_height="50dp" />

    </LinearLayout>

    <!-- Nội dung hóa đơn có thể cuộn -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Thông báo đặt hàng thành công -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ĐẶT HÀNG THÀNH CÔNG"
                android:textColor="#6A4FB3"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cảm ơn bạn đã mua hàng tại PT Mart - Mẹ &amp; Bé"
                android:textColor="#333333"
                android:textSize="16sp"
                android:gravity="center" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="18dp" />

            <!-- Mã đơn hàng -->
            <TextView
                android:id="@+id/txt_ma_don_hang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mã đơn hàng: DH001"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- Thông tin người nhận -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN NGƯỜI NHẬN"
                android:textColor="#FF9182"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_thong_tin_nguoi_nhan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thông tin người nhận"
                android:textColor="#333333"
                android:textSize="16sp"
                android:padding="8dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- Sản phẩm đã mua -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SẢN PHẨM ĐÃ MUA"
                android:textColor="#FF9182"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_san_pham_da_mua"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Danh sách sản phẩm"
                android:textColor="#333333"
                android:textSize="16sp"
                android:padding="8dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- Tổng tiền -->
            <TextView
                android:id="@+id/txt_tong_tien_hoadon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tổng tiền: 0 VND"
                android:textColor="#6A4FB3"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="8dp" />

            <!-- Trạng thái đơn hàng -->
            <TextView
                android:id="@+id/txt_trang_thai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trạng thái: Chờ xác nhận"
                android:textColor="#FF9182"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>

    <!-- Nút tiếp tục mua sắm -->
    <Button
        android:id="@+id/btn_tiep_tuc_mua_sam"
        android:layout_width="230dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:text="TIẾP TỤC MUA SẮM"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/custom_button_admin_page" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="15dp" />

</LinearLayout>