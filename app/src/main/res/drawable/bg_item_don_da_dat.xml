<?xml version="1.0" encoding="utf-8"?>

<!--
    Nền cho từng đơn đã đặt:
    nền trắng, bo góc và có viền nhẹ.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Màu nền của từng đơn -->
    <solid android:color="#FFFFFF" />

    <!-- Bo góc khung đơn -->
    <corners android:radius="12dp" />

    <!-- Viền nhẹ quanh đơn -->
    <stroke
        android:width="1dp"
        android:color="#D8C5EC" />

</shape>